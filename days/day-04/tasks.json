{
  "day": 4,
  "theme": "Matn ustasi — grep, sed, awk, pipe (to'liq kun)",
  "tasks": [
    {"id": "lines", "type": "real", "xp": 10, "block": "1️⃣ Yo'naltirish", "title": "Logда nechta qator?",
     "why": "Triage: avval hajmni bil — necha qatorli log bilan ishlayapsan.",
     "steps": ["Ishchi papkangga o't:  cd ~/devops/days/day-04/work",
               "Qatorlar sonini yoz:  wc -l < ~/devops/days/day-04/fixtures/server.log > lines.txt"],
     "expect": "lines.txt — server.log qatorlari soni",
     "check": "grep -qE '^[0-9]+$' $LAB/lines.txt"},

    {"id": "peek", "type": "real", "xp": 10, "block": "1️⃣ Yo'naltirish", "title": "Logга nazar (head)",
     "why": "Katta faylni ochmasdan boshini ko'rish — head.",
     "steps": ["access.log boshini saqla:  head -5 ~/devops/days/day-04/fixtures/access.log > peek.txt"],
     "expect": "peek.txt — access.log ning birinchi 5 qatori",
     "check": "[ -s $LAB/peek.txt ]"},

    {"id": "d_grep", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "grep -c bilan sana",
     "why": "Drill: naqshни tez sanash.",
     "steps": ["access.log da 'GET' so'rovlari SONINI yoz:  grep -c GET ~/devops/days/day-04/fixtures/access.log > getcount.txt"],
     "expect": "getcount.txt — GET qatorlari soni",
     "check": "grep -qE '^[0-9]+$' $LAB/getcount.txt"},

    {"id": "d_cut", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "cut bilan ustun ajrat",
     "why": "cut — ajratuvchi (delimiter) bo'yicha ustun oladi.",
     "steps": ["access.log 1-ustunini (IP) ajrat:  cut -d' ' -f1 ~/devops/days/day-04/fixtures/access.log > col1.txt"],
     "expect": "col1.txt — har qatordan 1-ustun (IP)",
     "check": "[ -s $LAB/col1.txt ]"},

    {"id": "d_sortuniq", "type": "real", "xp": 15, "block": "2️⃣ Drill — tezlik", "title": "sort | uniq -c zanjiri",
     "why": "Klassik tahlil: sanab, guruhlash.",
     "steps": ["IP larni sanab guruhlab yoz:",
               "cut -d' ' -f1 ~/devops/days/day-04/fixtures/access.log | sort | uniq -c | sort -rn > counts.txt"],
     "expect": "counts.txt — har IP necha marta (kamayish tartibida)",
     "check": "[ -s $LAB/counts.txt ] && grep -qE '[0-9]' $LAB/counts.txt"},

    {"id": "d_wc", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "wc bilan so'z sana",
     "why": "wc -l qator, -w so'z, -c bayt.",
     "steps": ["config.ini dagi SO'Zlar sonini yoz:  wc -w < ~/devops/days/day-04/fixtures/config.ini > words.txt"],
     "expect": "words.txt — so'zlar soni (raqam)",
     "check": "grep -qE '^[0-9]+$' $LAB/words.txt"},

    {"id": "errcount", "type": "real", "xp": 25, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Xatolarni sana (grep -c)",
     "why": "Minglab qatorli logда nechta ERROR — triage.",
     "steps": ["ERROR qatorlari SONINI yoz:",
               "grep -c ERROR ~/devops/days/day-04/fixtures/server.log > errors.txt"],
     "expect": "errors.txt = server.log dagi ERROR soni",
     "check": "[ \"$(cat $LAB/errors.txt 2>/dev/null)\" = \"$(grep -c ERROR $DAY/fixtures/server.log)\" ]"},

    {"id": "uniqip", "type": "real", "xp": 30, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Unikal IP'lar (awk + sort -u)",
     "why": "Kim kirgan? 1-ustun=IP. awk ustunni, sort -u unikalini.",
     "steps": ["Unikal IP'larni yoz:",
               "awk '{print $1}' ~/devops/days/day-04/fixtures/access.log | sort -u > ips.txt"],
     "expect": "ips.txt — unikal IP'lar (saralangan)",
     "check": "diff -q <(awk '{print $1}' $DAY/fixtures/access.log | sort -u) $LAB/ips.txt"},

    {"id": "sed", "type": "real", "xp": 25, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Configni tahrirla (sed)",
     "why": "Konfigда qiymat almashtirish — deploy avtomatikasi.",
     "steps": ["'debug=false' ni 'debug=true' ga almashtirib yoz:",
               "sed 's/debug=false/debug=true/' ~/devops/days/day-04/fixtures/config.ini > config.ini"],
     "expect": "work/config.ini — debug=true (false yo'q)",
     "check": "grep -qx 'debug=true' $LAB/config.ini && ! grep -q 'debug=false' $LAB/config.ini"},

    {"id": "topip", "type": "real", "xp": 30, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Eng faol IP (pipe zanjiri)",
     "why": "Kim eng ko'p so'rov yuborgan? sort|uniq -c|sort -rn — klassik zanjir.",
     "steps": ["Eng ko'p uchragan IP ni top, FAQAT IP ni yoz:",
               "awk '{print $1}' ~/devops/days/day-04/fixtures/access.log | sort | uniq -c | sort -rn | head -1 | awk '{print $2}' > topip.txt"],
     "expect": "topip.txt = eng ko'p so'rov yuborgan IP",
     "check": "grep -qx 10.0.0.5 $LAB/topip.txt"},

    {"id": "pkg", "type": "real", "xp": 20, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Paket versiyasini tekshir",
     "why": "Qaysi versiya o'rnatilgan? Audit/debug uchun muhim.",
     "steps": ["git versiyasini yoz:  git --version > gitver.txt"],
     "expect": "gitver.txt ичида 'git version ...'",
     "check": "grep -qi 'git version' $LAB/gitver.txt"},

    {"id": "cb_grep", "type": "real", "xp": 20, "block": "4️⃣ Callback (oldingi bilim)", "title": "grep -r (Day-1) — qaysi faylда?",
     "why": "Day-1 grep -r: papkadagi qaysi fayllarда 'ERROR' bor.",
     "steps": ["cd ~/devops/days/day-04/work && mkdir -p cb",
               "fixtures ичида 'ERROR' bor fayl(lar)ni top:",
               "grep -rl ERROR ~/devops/days/day-04/fixtures > cb/errfiles.txt"],
     "expect": "errfiles.txt — 'ERROR' uchragan fayl yo'l(lar)i",
     "check": "[ -s $LAB/cb/errfiles.txt ]"},

    {"id": "cb_proc", "type": "real", "xp": 20, "block": "4️⃣ Callback (oldingi bilim)", "title": "ps + pipe (Day-3) — jarayonlarni sana",
     "why": "Day-3 ps + bugungi pipe/wc: jarayonlar sonini hisobla.",
     "steps": ["Ishlab turgan jarayonlar sonini yoz:",
               "ps aux | wc -l > cb/proccount.txt"],
     "expect": "proccount.txt — jarayonlar soni",
     "check": "grep -qE '[0-9]' $LAB/cb/proccount.txt && [ \"$(tr -d ' ' < $LAB/cb/proccount.txt)\" -gt 5 ]"},

    {"id": "proj_init", "type": "real", "xp": 20, "block": "5️⃣ Mini-loyiha: Log Analyzer", "title": "Skeletni qur",
     "why": "Mini-loyiha: 'Log Analyzer'. Avval tuzilma.",
     "steps": ["cd ~/devops/days/day-04/work",
               "mkdir -p analyzer/out"],
     "expect": "analyzer/out mavjud",
     "check": "[ -d $LAB/analyzer/out ]"},

    {"id": "proj_err", "type": "real", "xp": 25, "block": "5️⃣ Mini-loyiha: Log Analyzer", "title": "Xatolar hisobi",
     "why": "Analyzer: server.log dagi ERROR sonini chiqar.",
     "steps": ["grep -c ERROR ~/devops/days/day-04/fixtures/server.log > analyzer/out/errors.txt"],
     "expect": "errors.txt = ERROR soni",
     "check": "[ \"$(cat $LAB/analyzer/out/errors.txt 2>/dev/null)\" = \"$(grep -c ERROR $DAY/fixtures/server.log)\" ]"},

    {"id": "proj_top", "type": "real", "xp": 25, "block": "5️⃣ Mini-loyiha: Log Analyzer", "title": "Eng faol 3 IP",
     "why": "Analyzer: eng ko'p so'rov yuborgan 3 IP.",
     "steps": ["awk '{print $1}' ~/devops/days/day-04/fixtures/access.log | sort | uniq -c | sort -rn | head -3 > analyzer/out/topips.txt"],
     "expect": "topips.txt — eng faol 3 IP (10.0.0.5 birinchi)",
     "check": "grep -q 10.0.0.5 $LAB/analyzer/out/topips.txt"},

    {"id": "proj_report", "type": "real", "xp": 30, "block": "5️⃣ Mini-loyiha: Log Analyzer", "title": "Hisobotni birlashtir (skript)",
     "why": "Loyiha yakuni: xatolar + top IP'larni bitta hisobotга.",
     "steps": ["analyzer/report.sh yoz (#!/bin/bash): errors va topips fayllarini birlashtirsin",
               "Masalan:  echo '== LOG REPORT =='; echo 'ERROR:'; cat analyzer/out/errors.txt; echo 'TOP IP:'; cat analyzer/out/topips.txt",
               "Ishga tushir:  bash analyzer/report.sh > analyzer/report.txt"],
     "expect": "report.txt — xatolar soni + top IP'lar",
     "check": "[ -s $LAB/analyzer/report.txt ] && grep -q 10.0.0.5 $LAB/analyzer/report.txt"},

    {"id": "explain", "type": "deep", "xp": 20, "block": "6️⃣ Yakuniy sinov", "title": "Kun xulosasi",
     "why": "Tushuntira olish — tushunganingning isboti.",
     "steps": ["pipe ( | ) nima qiladi va `grep` bilan `find` farqini ustozга ayt"],
     "expect": "O'z so'zlaring bilan qisqa tushuntirish"}
  ]
}
