{
  "day": 7,
  "theme": "1-hafta capstone — Health-Check (hamma ko'nikmani birlashtirish)",
  "tasks": [
    {"id": "ws", "type": "real", "xp": 15, "block": "1️⃣ Yo'naltirish", "title": "Loyiha tuzilmasi",
     "why": "1-hafta yakuni: real loyiha. Avval tartibli papka (Day-1).",
     "steps": ["Ishchi papkangga o't:  cd ~/devops/days/day-07/work",
               "mkdir -p health/bin health/logs"],
     "expect": "health/{bin,logs} mavjud",
     "check": "[ -d $LAB/health/bin ] && [ -d $LAB/health/logs ]"},

    {"id": "r_nav", "type": "real", "xp": 15, "block": "2️⃣ Hafta takrori", "title": "Day-1 takror (find)",
     "why": "Navigatsiya: ~/devops dagi .md fayllar sonini hisobla.",
     "steps": ["find $HOME/devops -name '*.md' | wc -l > health/logs/mdcount.txt"],
     "expect": "mdcount.txt — raqam",
     "check": "grep -qE '^[0-9]+$' $LAB/health/logs/mdcount.txt"},

    {"id": "r_perm", "type": "real", "xp": 15, "block": "2️⃣ Hafta takrori", "title": "Day-2 takror (chmod)",
     "why": "Ruxsat: bo'sh skript yaratib, executable qil.",
     "steps": ["health/bin/x.sh yarat (echo bilan) va executable qil:  chmod +x health/bin/x.sh"],
     "expect": "x.sh executable",
     "check": "[ -x $LAB/health/bin/x.sh ]"},

    {"id": "r_proc", "type": "real", "xp": 15, "block": "2️⃣ Hafta takrori", "title": "Day-3 takror (ps)",
     "why": "Jarayonlar: ishlab turgan jarayonlar sonini yoz.",
     "steps": ["ps aux | wc -l > health/logs/procs.txt"],
     "expect": "procs.txt — jarayonlar soni",
     "check": "grep -qE '[0-9]' $LAB/health/logs/procs.txt"},

    {"id": "r_text", "type": "real", "xp": 15, "block": "2️⃣ Hafta takrori", "title": "Day-4 takror (grep)",
     "why": "Matn: app.log dan ERROR sonini ajrat.",
     "steps": ["grep -c ERROR ~/devops/days/day-07/fixtures/app.log > health/logs/errcount.txt"],
     "expect": "errcount.txt = app.log dagi ERROR soni",
     "check": "[ \"$(cat $LAB/health/logs/errcount.txt 2>/dev/null)\" = \"$(grep -c ERROR $DAY/fixtures/app.log)\" ]"},

    {"id": "r_net", "type": "real", "xp": 15, "block": "2️⃣ Hafta takrori", "title": "Day-5 takror (dns)",
     "why": "Tarmoq: domenni IP ga aylantir.",
     "steps": ["getent hosts github.com > health/logs/dns.txt"],
     "expect": "dns.txt — github.com IP",
     "check": "[ -s $LAB/health/logs/dns.txt ] && grep -qE '[0-9a-f]+[:.][0-9a-f]+' $LAB/health/logs/dns.txt"},

    {"id": "script", "type": "real", "xp": 30, "block": "3️⃣ Health-Check loyiha", "title": "Monitoring skripti (Day-6 bash)",
     "why": "Day-6 bash + Day-1/3: server holatini chiqaruvchi skript.",
     "steps": ["health/bin/check.sh yarat (#!/bin/bash): hostname, nproc, df -h / chiqarsin",
               "Masalan:  echo \"Host: $(hostname)\"; echo \"CPU: $(nproc)\"; df -h /"],
     "expect": "check.sh hostname'ni chiqaradi",
     "check": "bash $LAB/health/bin/check.sh 2>/dev/null | grep -q \"$(hostname)\""},

    {"id": "perms", "type": "real", "xp": 20, "block": "3️⃣ Health-Check loyiha", "title": "Skriptni executable qil",
     "why": "Day-2: skript executable bo'lmasa ishlamaydi.",
     "steps": ["chmod +x health/bin/check.sh"],
     "expect": "check.sh executable",
     "check": "[ -x $LAB/health/bin/check.sh ]"},

    {"id": "logs", "type": "real", "xp": 25, "block": "3️⃣ Health-Check loyiha", "title": "Loglardan xatolar",
     "why": "Day-4: logдан ERROR sonini health hisobotга.",
     "steps": ["grep -c ERROR ~/devops/days/day-07/fixtures/app.log > health/logs/errors.txt"],
     "expect": "errors.txt = ERROR soni",
     "check": "[ \"$(cat $LAB/health/logs/errors.txt 2>/dev/null)\" = \"$(grep -c ERROR $DAY/fixtures/app.log)\" ]"},

    {"id": "run", "type": "real", "xp": 30, "block": "3️⃣ Health-Check loyiha", "title": "Ishga tushir va saqla",
     "why": "Hammasini birlashtirish: skriptni ishlatib, natijani saqlash.",
     "steps": ["./health/bin/check.sh > health/logs/report.txt   (work papkasidan)",
               "Ko'r:  cat health/logs/report.txt"],
     "expect": "report.txt ичида hostname",
     "check": "grep -q \"$(hostname)\" $LAB/health/logs/report.txt"},

    {"id": "p_net", "type": "real", "xp": 25, "block": "4️⃣ Kengaytirish", "title": "Tarmoq tekshiruvini qo'sh",
     "why": "Day-5: health'ga tarmoq holatini (curl status) qo'shamiz.",
     "steps": ["curl -sI https://github.com | grep -i '^HTTP' > health/logs/net.txt"],
     "expect": "net.txt — HTTP status qatori",
     "check": "grep -qi 'HTTP/' $LAB/health/logs/net.txt"},

    {"id": "p_disk", "type": "real", "xp": 20, "block": "4️⃣ Kengaytirish", "title": "Disk holatini qo'sh",
     "why": "Disk holati ham health'ning bir qismi.",
     "steps": ["df -h / | tail -1 > health/logs/disk.txt"],
     "expect": "disk.txt — disk foydalanish (%)",
     "check": "grep -qE '[0-9]+%' $LAB/health/logs/disk.txt"},

    {"id": "p_main", "type": "real", "xp": 35, "block": "4️⃣ Kengaytirish", "title": "To'liq hisobot (birlashtir)",
     "why": "Capstone yakuni: barcha qismni bitta to'liq hisobotга birlashtirish.",
     "steps": ["health/bin/health.sh yoz (#!/bin/bash): report + errors + net + disk ni birlashtirsin",
               "Masalan:  echo '== HEALTH =='; cat health/logs/report.txt; echo 'NET:'; cat health/logs/net.txt; echo 'ERROR:'; cat health/logs/errors.txt",
               "Ishga tushir:  bash health/bin/health.sh > health/report-full.txt"],
     "expect": "report-full.txt — hostname + tarmoq holati birga",
     "check": "grep -q \"$(hostname)\" $LAB/health/report-full.txt && grep -qi HTTP $LAB/health/report-full.txt"},

    {"id": "explain", "type": "deep", "xp": 25, "block": "6️⃣ Yakuniy sinov", "title": "1-hafta xulosasi",
     "why": "Haftani umumlashtirish — bilimni mustahkamlaydi.",
     "steps": ["1-haftada o'rgangan 3 ta eng muhim narsani (navigatsiya, ruxsat, jarayon, matn, tarmoq, bash'dan) ustozга ayt"],
     "expect": "O'z so'zlaring bilan haftaning xulosasi"}
  ]
}
