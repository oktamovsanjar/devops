{
  "day": 2,
  "theme": "Ruxsatlar va egalik — chmod, chown, sudo (to'liq kun)",
  "tasks": [
    {"id": "lsperm", "type": "real", "xp": 10, "block": "1️⃣ Yo'naltirish", "title": "Ruxsatlarni o'qi (ls -l)",
     "why": "ls -l birinchi ustuni — ruxsatlar (-rwxr-xr--). Hammasi shundan boshlanadi.",
     "steps": ["Ishchi papkangga o't:  cd ~/devops/days/day-02/work",
               "Bir fayl yarat va ruxsatini ko'r:  touch a.txt && ls -l a.txt > perms.txt"],
     "expect": "perms.txt — a.txt ning ls -l qatori",
     "check": "[ -s $LAB/perms.txt ] && grep -q 'a.txt' $LAB/perms.txt"},

    {"id": "whoami", "type": "real", "xp": 10, "block": "1️⃣ Yo'naltirish", "title": "Kimman, qaysi guruh",
     "why": "Ruxsat ega/guruhga bog'liq — avval o'zingni bil.",
     "steps": ["Foydalanuvchi va guruhlaringni yoz:  id > id.txt"],
     "expect": "id.txt — uid/gid ma'lumoti",
     "check": "[ -s $LAB/id.txt ] && grep -qi uid $LAB/id.txt"},

    {"id": "d_600", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "chmod 600 drill",
     "why": "Tez ruxsat o'rnatish — muscle memory.",
     "steps": ["touch k.txt && chmod 600 k.txt", "Tekshir:  ls -l k.txt  → -rw-------"],
     "expect": "k.txt = 600",
     "check": "[ \"$(stat -c %a $LAB/k.txt 2>/dev/null)\" = 600 ]"},

    {"id": "d_755", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "chmod 755 drill",
     "why": "Skript/papka uchun klassik ruxsat.",
     "steps": ["touch s.sh && chmod 755 s.sh"],
     "expect": "s.sh = 755",
     "check": "[ \"$(stat -c %a $LAB/s.sh 2>/dev/null)\" = 755 ]"},

    {"id": "d_x", "type": "real", "xp": 10, "block": "2️⃣ Drill — tezlik", "title": "chmod +x drill",
     "why": "Harfli usul: +x execute bitini qo'shadi.",
     "steps": ["touch t.sh && chmod +x t.sh"],
     "expect": "t.sh executable",
     "check": "[ -x $LAB/t.sh ]"},

    {"id": "secret", "type": "real", "xp": 25, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Maxfiy fayl (600)",
     "why": "Parol/kalit fayllari faqat egasiga ochiq — xavfsizlik asosi.",
     "steps": ["secret.txt yarat (touch)",
               "Ruxsatini AYNAN 600 qil:  chmod 600 secret.txt",
               "Tekshir:  ls -l secret.txt  → -rw-------"],
     "expect": "secret.txt = 600 (rw-------)",
     "check": "[ -f $LAB/secret.txt ] && [ $(stat -c %a $LAB/secret.txt) = 600 ]"},

    {"id": "exec", "type": "real", "xp": 25, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Skriptni executable qil",
     "why": "Yangi skript default'da ishlamaydi — +x kerak.",
     "steps": ["work da run.sh yarat, ichiga:  echo 'ishladi'",
               "Bajariladigan qil:  chmod +x run.sh",
               "Ishlat:  ./run.sh"],
     "expect": "run.sh executable (x biti bor)",
     "check": "[ -x $LAB/run.sh ]"},

    {"id": "public", "type": "real", "xp": 20, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Ommaviy fayl (644)",
     "why": "Oddiy fayllar uchun klassik: ega rw, qolganlar r (644).",
     "steps": ["public.txt yarat", "Ruxsatini 644 qil:  chmod 644 public.txt"],
     "expect": "public.txt = 644 (rw-r--r--)",
     "check": "[ -f $LAB/public.txt ] && [ $(stat -c %a $LAB/public.txt) = 644 ]"},

    {"id": "private", "type": "real", "xp": 20, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Yopiq papka (700)",
     "why": "Faqat o'zingга ochiq papka — boshqalar kira olmaydi (700).",
     "steps": ["'private' papka yarat (mkdir)", "Ruxsatini 700 qil:  chmod 700 private"],
     "expect": "private/ = 700 (rwx------)",
     "check": "[ -d $LAB/private ] && [ $(stat -c %a $LAB/private) = 700 ]"},

    {"id": "hide", "type": "real", "xp": 25, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Boshqalardan yashir (o-rwx)",
     "why": "Jamoa fayli: ega/guruh ishlaydi, 'others' ko'rmasin.",
     "steps": ["team.txt yarat", "Faqat 'others' ruxsatini olib tashla:  chmod o-rwx team.txt"],
     "expect": "team.txt — 'others' uchun hech qanday ruxsat yo'q",
     "check": "[ -f $LAB/team.txt ] && ! find $LAB/team.txt -perm /007 -print 2>/dev/null | grep -q ."},

    {"id": "own", "type": "real", "xp": 20, "block": "3️⃣ Asosiy ko'nikmalar", "title": "Egani o'zgartir (chown)",
     "why": "chown — faylning EGASINI o'zgartiradi (sudo kerak). Ko'p ish root egaligini talab qiladi.",
     "steps": ["Fayl yarat:  touch owned.txt",
               "Egasini ko'r:  ls -l owned.txt   (ega: ubuntu)",
               "Egani root qil:  sudo chown root owned.txt",
               "Tekshir:  ls -l owned.txt   (endi ega: root)"],
     "expect": "owned.txt egasi = root (chown ishladi)",
     "check": "[ \"$(stat -c %U $LAB/owned.txt 2>/dev/null)\" = root ]"},

    {"id": "cb_find", "type": "real", "xp": 20, "block": "4️⃣ Callback (oldingi bilim)", "title": "find + ruxsat (Day-1)",
     "why": "Day-1 find: work ichидаги .sh fayllarni topib ro'yxatla.",
     "steps": ["cd ~/devops/days/day-02/work && mkdir -p cb",
               "find . -name '*.sh' -type f > cb/scripts.txt"],
     "expect": "scripts.txt — .sh fayllar (run.sh shular ichида)",
     "check": "grep -q '.sh' $LAB/cb/scripts.txt"},

    {"id": "cb_script", "type": "real", "xp": 20, "block": "4️⃣ Callback (oldingi bilim)", "title": "Skript + ruxsat",
     "why": "Skript yoz, executable qil, ishga tushir — to'liq sikl.",
     "steps": ["cb/show.sh yarat:  echo 'Ruxsatlar:'; ls -l",
               "Bajariladigan qil:  chmod +x cb/show.sh",
               "Ishlat:  ./cb/show.sh"],
     "expect": "show.sh executable va ishlaydi",
     "check": "[ -x $LAB/cb/show.sh ] && bash $LAB/cb/show.sh 2>/dev/null | grep -qi ruxsat"},

    {"id": "proj_init", "type": "real", "xp": 20, "block": "5️⃣ Mini-loyiha: Secure Setup", "title": "Skeletni qur",
     "why": "Mini-loyiha: xavfsiz papka tuzilmasi.",
     "steps": ["cd ~/devops/days/day-02/work",
               "mkdir -p secure/public secure/private"],
     "expect": "secure/{public,private} mavjud",
     "check": "[ -d $LAB/secure/public ] && [ -d $LAB/secure/private ]"},

    {"id": "proj_perms", "type": "real", "xp": 25, "block": "5️⃣ Mini-loyiha: Secure Setup", "title": "Papka ruxsatlari",
     "why": "public hammaga (755), private faqat egaga (700).",
     "steps": ["chmod 755 secure/public", "chmod 700 secure/private"],
     "expect": "public=755, private=700",
     "check": "[ \"$(stat -c %a $LAB/secure/public)\" = 755 ] && [ \"$(stat -c %a $LAB/secure/private)\" = 700 ]"},

    {"id": "proj_key", "type": "real", "xp": 30, "block": "5️⃣ Mini-loyiha: Secure Setup", "title": "Maxfiy kalit (600)",
     "why": "Yakuniy: private ичида 600 ruxsatli kalit fayl.",
     "steps": ["secure/private/key.txt yarat", "chmod 600 secure/private/key.txt"],
     "expect": "key.txt = 600, private ичида",
     "check": "[ -f $LAB/secure/private/key.txt ] && [ \"$(stat -c %a $LAB/secure/private/key.txt)\" = 600 ]"},

    {"id": "boss", "type": "lab", "xp": 250, "block": "6️⃣ Yakuniy sinov", "title": "BOSS — 'Qulflangan Ruxsatlar'",
     "why": "Ruxsatlarni real to'siqda yengish:  chmod (read) → chmod +x → sudo.",
     "steps": ["cd ~/devops/days/day-02/quest && cat START.txt",
               "4 bosqichni yech, DEVOPS{...} flagni top",
               "Topshir:  devops verify"],
     "expect": "DEVOPS{...} flag topiladi va topshiriladi",
     "flag": "DEVOPS{permission_master_rwx_unlocked}"},

    {"id": "explain", "type": "deep", "xp": 20, "block": "6️⃣ Yakuniy sinov", "title": "Kun xulosasi",
     "why": "Tushuntira olish — haqiqatan tushunganingning isboti.",
     "steps": ["chmod 755 va 644 farqini + 'ega bo'lsam ham nega 000 ni o'qiy olmadim' ni ustozга ayt"],
     "expect": "O'z so'zlaring bilan qisqa tushuntirish"}
  ]
}
